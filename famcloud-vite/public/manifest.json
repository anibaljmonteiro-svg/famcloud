{
  "name": "FamCloud",
  "short_name": "FamCloud",
  "description": "A tua cloud familiar privada e segura",
  "start_url": "/famcloud/",
  "scope": "/famcloud/",
  "display": "standalone",
  "background_color": "#faf7f2",
  "theme_color": "#c4956a",
  "orientation": "any",
  "categories": ["productivity", "utilities"],
  "share_target": {
    "action": "/famcloud/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{ "name": "files", "accept": ["image/*", "video/*", "application/pdf", ".doc", ".docx", ".xls", ".xlsx"] }]
    }
  },
  "icons": [
    { "src": "/famcloud/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/famcloud/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ]
}
