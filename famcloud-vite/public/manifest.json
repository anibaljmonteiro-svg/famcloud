{
  "name": "FamCloud",
  "short_name": "FamCloud",
  "description": "Armazenamento familiar privado e seguro na tua cloud pessoal",
  "start_url": "/famcloud/",
  "scope": "/famcloud/",
  "display": "standalone",
  "background_color": "#3f35c8",
  "theme_color": "#3f35c8",
  "orientation": "any",
  "categories": [
    "productivity",
    "utilities"
  ],
  "share_target": {
    "action": "/famcloud/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "files",
          "accept": [
            "image/*",
            "video/*",
            "application/pdf",
            ".doc",
            ".docx",
            ".xls",
            ".xlsx"
          ]
        }
      ]
    }
  },
  "icons": [
    {
      "src": "/famcloud/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/famcloud/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/famcloud/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/famcloud/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Carregar ficheiro",
      "short_name": "Upload",
      "description": "Carregar ficheiros para a FamCloud",
      "url": "/famcloud/?action=upload",
      "icons": [
        {
          "src": "/famcloud/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Câmara",
      "short_name": "Câmara",
      "description": "Tirar foto e carregar",
      "url": "/famcloud/?action=camera",
      "icons": [
        {
          "src": "/famcloud/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Pesquisar",
      "short_name": "Pesquisa",
      "description": "Pesquisar ficheiros",
      "url": "/famcloud/?action=search",
      "icons": [
        {
          "src": "/famcloud/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/famcloud/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "FamCloud — A tua cloud familiar"
    },
    {
      "src": "/famcloud/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "FamCloud — Gestão de ficheiros familiar"
    }
  ],
  "lang": "pt-PT",
  "dir": "ltr",
  "id": "/famcloud/"
}